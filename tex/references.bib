@article{taneda_visual_1977,
	title = {Visual study of unsteady separated flows around bodies},
	volume = {17},
	abstract = {Photography is employed to study the streamline and streakline flow patterns around two-dimensional shapes executing basic unsteady motions in an incompressible viscous fluid. The shapes used are circular and elliptic cylinders, and flat and flexible plates; unsteady motions investigated include the impulsive start from rest, change of velocity, translatory oscillation, change of the angle of incidence, uniform rotation, rotatory oscillation and swimming motion. The behavior of the boundary layer (vortex sheet), the initially irrotational flow of a body starting from rest impulsively, the hysteresis flow encountered when a body executes a translatory or rotatory oscillation, and the role of centrifugal forces in the rotation of a body in a steady flow are discussed.},
